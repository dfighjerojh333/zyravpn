function loadJsonp(url, callbackParam){
return new Promise(function(resolve, reject){
var callbackName = "__ipLookup_" + Date.now() + Math.floor(Math.random() * 10000);
var script = document.createElement("script"); var finished = false; var paramName = callbackParam || "callback";
function cleanup(){ finished = true; if (script.parentNode) script.parentNode.removeChild(script); try { delete window[callbackName]; } catch (e) {} }
window[callbackName] = function(data){ cleanup(); resolve(data); };
script.onerror = function(){ if(finished)return; cleanup(); reject(new Error("Fail")); };
script.src = url + (url.indexOf("?") === -1 ? "?" : "&") + paramName + "=" + callbackName;
document.head.appendChild(script);
setTimeout(function(){ if(finished)return; cleanup(); reject(new Error("Timeout")); }, 6000);
});
}
function loadGeo(){
return new Promise(function(resolve, reject){
var script = document.createElement("script"); var finished = false;
function cleanup(){ finished = true; if (script.parentNode) script.parentNode.removeChild(script); try { delete window.geoip; } catch (e) {} }
window.geoip = function(data){ cleanup(); resolve(data); };
script.onerror = function(){ if(finished)return; cleanup(); reject(new Error("Fail")); };
script.src = "https://get.geojs.io/v1/ip/geo.js";
document.head.appendChild(script);
setTimeout(function(){ if(finished)return; cleanup(); reject(new Error("Timeout")); }, 6000);
}).then(function(data){
if(data) { setText("ip-city", data.city || data.city_name || "—"); setText("ip-region", data.region || data.regionName || data.state || "—"); setText("ip-country", data.country || data.country_name || "—"); setText("ip-isp", data.isp || data.organization_name || data.organization || data.org || "—"); if(data.ip) setText("user-ip", data.ip); }
});
}
