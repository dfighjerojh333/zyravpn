</nav>

<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hurry-banner">
          <span data-i18n="hurry_txt">⚡ HURRY: First 10,000 users get 6 MONTHS FREE. Spots left:</span>
          <span class="spots-count">438</span>
        </div>
        <h1 data-i18n="hero_h1">Declassified <span class="text-primary glow-text">Military VPN</span> for Public Use</h1>
        <p class="sub" style="margin:1.25rem 0" data-i18n="hero_sub">Originally developed for secure military communications. Hide your IP, encrypt your traffic, and become completely untraceable online.</p>
        
        <button class="btn-primary glow-primary" onclick="startInstallation()">
          <svg class="icon icon-sm" style="stroke:var(--primary-fg)" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span data-i18n="btn_dl">Download for Windows</span>
        </button>
        <p class="note" style="margin-top:1rem; font-size:0.875rem;" data-i18n="hero_note">Windows 10 / 11 • 6 Months Free • No credit card required</p>
      </div>
      <div style="display:flex;justify-content:center">
        <svg class="hero-img" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M100 20L20 50V100C20 150 100 190 100 190C100 190 180 150 180 100V50L100 20Z" fill="url(#grad1)" stroke="#00D68F" stroke-width="4"/>
          <path d="M100 50L50 70V100C50 135 100 160 100 160C100 160 150 135 150 100V70L100 50Z" fill="#0A1526" stroke="#00D68F" stroke-width="2"/>
          <circle cx="100" cy="105" r="20" fill="#00D68F" opacity="0.8"/>
          <path d="M90 105L98 113L115 95" stroke="#0A1526" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
          <defs>
            <linearGradient id="grad1" x1="100" y1="20" x2="100" y2="190" gradientUnits="userSpaceOnUse">
              <stop stop-color="#00D68F" stop-opacity="0.2"/><stop offset="1" stop-color="#0A1526" stop-opacity="0.8"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
    </div>
  </div>
</section>

<section class="ip-section">
  <div class="container">
    <div class="ip-card glass">
      <div style="display:flex;align-items:center;justify-content:center;gap:0.5rem">
        <svg class="icon icon-destructive animate-pulse" viewBox="0 0 24 24"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <h2 class="text-destructive" style="font-size:1.5rem;font-weight:700" data-i18n="ip_h2">Your IP Is Exposed!</h2>
      </div>
      <div class="ip-box">
        <p class="label" style="display:flex;align-items:center;justify-content:center;gap:0.375rem">
          <svg class="icon icon-destructive" style="width:0.75rem;height:0.75rem" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span data-i18n="ip_lbl">YOUR IP ADDRESS</span>
        </p>
        <p class="ip" id="user-ip">Loading...</p>
      </div>
      <div class="ip-grid" id="ip-details">
        <div><p class="label" data-i18n="l_city">City</p><p class="value" id="ip-city">—</p></div>
        <div><p class="label" data-i18n="l_reg">Region</p><p class="value" id="ip-region">—</p></div>
        <div><p class="label" data-i18n="l_cou">Country</p><p class="value" id="ip-country">—</p></div>
        <div><p class="label" data-i18n="l_isp">ISP</p><p class="value" id="ip-isp">—</p></div>
      </div>
      <p style="font-size:0.75rem;color:var(--muted);max-width:28rem;margin:0 auto" data-i18n="ip_desc">Without a VPN, websites, hackers, and your ISP can see your exact location and track everything you do online.</p>
    </div>
  </div>
</section>

<section class="stats">
  <div class="container">
    <div class="stats-grid">
      <div><p class="num glow-text">90+</p><p class="lbl" data-i18n="s_cou">Countries</p></div>
