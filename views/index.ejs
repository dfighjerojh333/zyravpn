<section class="features" id="features">
  <div class="container">
    <div class="section-title">
      <h2 data-i18n="feat_h2">Why Choose <span class="text-primary">ZyraPrivate</span>?</h2>
      <p data-i18n="feat_sub">Built for people who value absolute privacy. Powered by military technologies.</p>
    </div>
    <div class="features-grid">
      <div class="feature-card glass">
        <div class="icon-wrap"><svg class="icon" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
        <h3 data-i18n="f1_t">Military AES-256</h3>
        <p data-i18n="f1_d">The exact same encryption standard used by government agencies to protect classified information.</p>
      </div>
