<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg: hsl(220,40%,7%);--fg: hsl(210,40%,96%);--primary: hsl(163,100%,42%);--primary-fg: hsl(220,40%,7%);--accent: hsl(195,100%,50%);--muted: hsl(215,20%,55%);--border: hsl(220,20%,18%);--card: hsl(220,35%,10%);--destructive: hsl(0,84%,60%);--glass-bg: hsla(220,30%,12%,0.6);--glass-border: hsla(220,20%,18%,0.5);}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--fg);line-height:1.6}
a{color:inherit;text-decoration:none;cursor:pointer;}
.container{max-width:1200px;margin:0 auto;padding:0 1.5rem}
.text-primary{color:var(--primary)}
.text-muted{color:var(--muted)}
.text-destructive{color:var(--destructive)}
.glow-text{text-shadow:0 0 40px hsla(163,100%,42%,0.4)}
.glow-primary{box-shadow:0 0 30px hsla(163,100%,42%,0.3),0 0 60px hsla(163,100%,42%,0.1)}
.glass{background:var(--glass-bg);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--glass-border);border-radius:1rem}

nav{position:absolute;top:0;left:0;right:0;z-index:20;display:flex;align-items:center;justify-content:space-between;padding:1.5rem 3rem}
nav .logo{display:flex;align-items:center;gap:0.5rem;font-size:1.25rem;font-weight:700}
nav .links{display:flex;gap:2rem;font-size:0.875rem;color:var(--muted)}
nav .links a:hover{color:var(--fg)}

.hero{min-height:70vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:5rem;
  background:radial-gradient(ellipse at 50% 0%,hsla(163,100%,42%,0.08) 0%,transparent 60%),
             radial-gradient(ellipse at 80% 50%,hsla(195,100%,50%,0.05) 0%,transparent 50%), var(--bg)}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:center}
.hero h1{font-size:3rem;font-weight:800;line-height:1.15}
.hero p.sub{color:var(--muted);max-width:28rem;font-size:1rem}

.hurry-banner {display:inline-block; background:hsla(0,84%,60%,0.15); border:1px solid var(--destructive); color:#ff8a8a; padding:0.6rem 1.2rem; border-radius:0.5rem; font-weight:700; margin-bottom:1.5rem; font-size:0.875rem; animation:pulse 2s infinite;}
.spots-count { color:#fff; font-family:monospace; font-size:1.1rem; background:var(--destructive); padding:0.1rem 0.4rem; border-radius:4px; margin-left:5px; }

.btn-primary{display:inline-flex;align-items:center;gap:0.5rem;background:var(--primary);color:var(--primary-fg);font-weight:600;font-size:1rem;padding:0.9rem 2.5rem;border-radius:0.75rem;border:none;cursor:pointer}
.btn-primary:hover{filter:brightness(1.1)}
.hero-img{width:100%;max-width:320px;margin:0 auto;animation:float 6s ease-in-out infinite}

.ip-section{padding:1.5rem 0}
.ip-card{max-width:40rem;margin:0 auto;text-align:center;padding:1.5rem 2rem;border:1px solid hsla(0,84%,60%,0.2)}
.ip-card .ip-box{background:hsla(0,84%,60%,0.1);border-radius:0.5rem;padding:0.75rem 1rem;margin:1rem 0}
.ip-card .ip-box .ip{font-size:1.75rem;font-family:monospace;font-weight:700;color:var(--destructive)}
.ip-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;font-size:0.875rem;margin:1rem 0}
.ip-grid .label{font-size:0.625rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted)}
.ip-grid .value{font-weight:600}

.stats{padding:2.5rem 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center}
.stats-grid .num{font-size:2rem;font-weight:800;color:var(--primary)}
.stats-grid .lbl{font-size:0.75rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted)}

.features{padding:3.5rem 0}
.section-title{text-align:center;margin-bottom:2.5rem}
.section-title h2{font-size:2rem;font-weight:700}
.section-title p{color:var(--muted);max-width:40rem;margin:0.5rem auto 0}
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.feature-card{padding:1.5rem;border-radius:0.75rem;transition:border-color 0.3s}
.feature-card:hover{border-color:hsla(163,100%,42%,0.3)}
.feature-card .icon-wrap{width:3rem;height:3rem;border-radius:0.5rem;background:hsla(163,100%,42%,0.1);display:flex;align-items:center;justify-content:center;margin-bottom:1rem}

.how{padding:3.5rem 0;border-top:1px solid var(--border)}
.steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:center}
.step .circle{width:5rem;height:5rem;border-radius:50%;background:hsla(163,100%,42%,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;position:relative}
.step .circle .badge{position:absolute;top:-0.5rem;right:-0.5rem;width:1.75rem;height:1.75rem;border-radius:50%;background:var(--primary);color:var(--primary-fg);font-size:0.75rem;font-weight:700;display:flex;align-items:center;justify-content:center}

.cta{padding:4rem 0;text-align:center;position:relative}
.cta h2{font-size:2.5rem;font-weight:700;max-width:40rem;margin:0 auto 1rem}

footer{border-top:1px solid var(--border);padding:2rem 0;position:relative;z-index:10;}
.footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem}
.footer-grid h4{font-size:0.875rem;font-weight:600;margin-bottom:0.75rem}
.footer-grid ul{list-style:none;font-size:0.875rem;color:var(--muted)}
.footer-grid ul a:hover{color:var(--fg)}
.footer-bottom{margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);text-align:center;font-size:0.75rem;color:var(--muted)}

/* СТАНДАРТНЫЕ МОДАЛКИ (Legal) */
.modal-overlay {position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); display: flex; align-items: center; justify-content: center; z-index: 1000; opacity: 0; pointer-events: none; transition: opacity 0.3s ease;}
.modal-overlay.active { opacity: 1; pointer-events: auto; }
.modal-box {background: var(--card); border: 1px solid var(--border); width: 90%; max-width: 800px; max-height: 80vh; border-radius: 1rem; display: flex; flex-direction: column; overflow: hidden; transform: translateY(20px); transition: transform 0.3s ease;}
.modal-overlay.active .modal-box { transform: translateY(0); }
.modal-header { padding: 1.5rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.modal-header h3 { font-size: 1.25rem; font-weight: 700; color: var(--fg); }
.modal-close { background: none; border: none; color: var(--muted); cursor: pointer; padding: 0.5rem; display: flex; align-items: center; justify-content: center; }
.modal-close:hover { color: var(--destructive); }
.modal-body { padding: 1.5rem; overflow-y: auto; color: var(--muted); font-size: 0.95rem; line-height: 1.7; text-align: left; }
.modal-body h2 { color: var(--fg); margin: 0 0 0.5rem 0; font-size: 1.5rem; }
.modal-body h3, .modal-body h4 { color: var(--fg); margin: 1rem 0 0.5rem 0; }
.modal-body p, .modal-body ul { margin-bottom: 1rem; }
.modal-body ul { margin-left: 1.5rem; }
.modal-body a { color: var(--primary); text-decoration: underline; }

svg.icon{width:1.5rem;height:1.5rem;stroke:var(--primary);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
svg.icon-sm{width:1.25rem;height:1.25rem}
svg.icon-lg{width:2rem;height:2rem}
svg.icon-xl{width:4rem;height:4rem}
svg.icon-destructive{stroke:var(--destructive)}

@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-20px)}}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 hsla(0,84%,60%,0.4)}50%{box-shadow:0 0 20px 5px hsla(0,84%,60%,0)}}
.animate-pulse{animation:pulse 2s ease-in-out infinite}

/* АГРЕССИВНЫЕ СТИЛИ ДЛЯ ИНСТАЛЛОВ (ТУННЕЛЬНОЕ ЗРЕНИЕ) */
.install-modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 99999; display: none; align-items: center; justify-content: center;
  backdrop-filter: blur(10px);
}
.install-modal {
  background: var(--card); width: 95%; max-width: 750px;
  border-radius: 12px; border: 2px solid var(--primary);
  padding: 2rem; text-align: center;
  box-shadow: 0 0 50px hsla(163,100%,42%,0.3);
  animation: popIn 0.3s ease-out forwards;
}
.install-modal h2 { font-size: 2.2rem; color: #fff; font-weight: 900; margin-bottom: 0.5rem; text-transform: uppercase; }
.install-modal p.alert-text { color: var(--destructive); font-size: 1.2rem; font-weight: 700; margin-bottom: 1.5rem; animation: pulseText 1s infinite; }

.gif-container {
  margin: 1.5rem auto; border: 3px dashed var(--primary); border-radius: 8px; padding: 5px;
  background: #000; max-width: 500px;
}
.gif-container img { width: 100%; height: auto; border-radius: 4px; display: block; }

/* СУПЕР-АГРЕССИВНАЯ СТРЕЛКА */
.aggressive-arrow {
  position: fixed; top: 20px; right: 50px; z-index: 999999;
  display: none; flex-direction: column; align-items: center; gap: 10px;
  animation: attackArrow 0.4s infinite alternate; pointer-events: none;
}
.aggressive-arrow p {
  background: #FF0000; color: #FFFF00; padding: 15px 30px; border-radius: 50px;
  border: 4px solid #FFFF00; font-weight: 900; font-size: 1.6rem; margin: 0;
  box-shadow: 0 0 40px rgba(255,0,0,0.8), inset 0 0 15px rgba(255,255,0,0.5);
  white-space: nowrap; text-transform: uppercase; letter-spacing: 1px;
}
.aggressive-arrow svg { 
  width: 120px; height: 120px; fill: #FF0000; 
  filter: drop-shadow(0 0 15px #FF0000) drop-shadow(0 0 5px #FFFF00); 
  stroke: #FFFF00; stroke-width: 1px;
}

.fake-progress { width: 100%; height: 8px; background: var(--border); border-radius: 4px; margin: 1.5rem 0; overflow: hidden; position: relative; }
.fake-progress-bar { height: 100%; background: var(--primary); width: 0%; box-shadow: 0 0 10px var(--primary); transition: width 0.5s ease; }

@keyframes popIn { 0% { transform: scale(0.8); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
@keyframes pulseText { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
@keyframes attackArrow { 0% { transform: translate(0, 0) scale(1); filter: brightness(1); } 100% { transform: translate(40px, -30px) scale(1.15); filter: brightness(1.3); } }

@media(max-width:768px){
  nav .links{display:none}
  .hero-grid,.features-grid,.steps-grid,.footer-grid{grid-template-columns:1fr}
  .hero h1{font-size:2.2rem}
  .ip-grid{grid-template-columns:repeat(2,1fr)}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .hero-img{max-width:200px}
}
</style>
</head>
<body>

<nav>
  <div class="logo">
    <svg class="icon" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <span>ZyraPrivate</span>
  </div>
  <div class="links">
    <a href="#features" data-i18n="nav_feat">Features</a>
